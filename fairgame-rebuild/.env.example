NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://fairgame:password@ep-example.us-east-1.aws.neon.tech/fairgame?sslmode=require
FAIRGAME_WEB_DIST_DIR=/app/apps/web/dist
FAIRGAME_ALLOWED_ORIGINS=https://play.example.com
FAIRGAME_SECURE_COOKIES=true
FAIRGAME_TRUST_PROXY=true
FAIRGAME_RATE_LIMIT_WINDOW_MS=60000
FAIRGAME_RATE_LIMIT_MAX=120
FAIRGAME_STALE_MATCH_MAX_AGE_MS=86400000
FAIRGAME_CLEANUP_INTERVAL_MS=300000
FAIRGAME_JSON_BODY_LIMIT=64kb
FAIRGAME_LOG_LEVEL=info
