{
  "name": "fairgame-rebuild",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/domain",
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @fairgame/server\" \"npm run dev -w @fairgame/web\"",
    "dev:server": "npm run dev -w @fairgame/server --",
    "dev:web": "npm run dev -w @fairgame/web --",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.19.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.13"
  }
}
