{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build:packages && npm run build -w @fairgame/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://p01--two-boards--6wlsqmd2hdrc.code.run/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://p01--two-boards--6wlsqmd2hdrc.code.run/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
